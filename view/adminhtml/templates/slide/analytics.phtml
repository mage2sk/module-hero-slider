$ctr7     = $block->ctr($totals7['views'], $totals7['clicks']);

$breakdown = $block->getDeviceBreakdown(30);
$timeline  = $block->getTimeline(30);

$max = 1;
foreach ($timeline as $row) {
    $max = max($max, $row['views'], $row['clicks']);
}
$buildPath = static function (array $timeline, string $key, int $max, int $w, int $h): string {
    $count = count($timeline);
    if ($count < 2) {
        return '';
    }
    $points = [];
    foreach ($timeline as $i => $row) {
        $x = round($i * ($w / ($count - 1)), 2);
        $y = round($h - ($row[$key] / $max) * $h, 2);
        $points[] = $x . ',' . $y;
    }
    return implode(' ', $points);
};
$viewsLine  = $buildPath($timeline, 'views', $max, 600, 80);
$clicksLine = $buildPath($timeline, 'clicks', $max, 600, 80);

