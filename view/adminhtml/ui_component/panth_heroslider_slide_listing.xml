<?xml version="1.0"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">panth_heroslider_slide_listing.panth_heroslider_slide_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>panth_heroslider_slide_columns</spinner>
        <deps>
            <dep>panth_heroslider_slide_listing.panth_heroslider_slide_listing_data_source</dep>
        </deps>
        <buttons>
            <button name="add">
                <url path="*/*/new"/>
                <class>primary</class>
                <label translate="true">Add New Slide</label>
            </button>
        </buttons>
    </settings>
    <dataSource name="panth_heroslider_slide_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">entity_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>Panth_HeroSlider::slides</aclResource>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider"
                      name="panth_heroslider_slide_listing_data_source">
            <settings>
                <requestFieldName>entity_id</requestFieldName>
                <primaryFieldName>entity_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <massaction name="listing_massaction">
            <action name="delete">
                <settings>
                    <confirm>
                        <message translate="true">Are you sure you want to delete the selected slides?</message>
                        <title translate="true">Delete slides</title>
                    </confirm>
                    <url path="panth_heroslider/slide/massDelete"/>
                    <type>delete</type>
                    <label translate="true">Delete</label>
                </settings>
            </action>
            <action name="enable">
                <settings>
                    <url path="panth_heroslider/slide/massStatus">
                        <param name="status">1</param>
                    </url>
                    <type>enable</type>
                    <label translate="true">Enable</label>
                </settings>
            </action>
            <action name="disable">
                <settings>
                    <url path="panth_heroslider/slide/massStatus">
                        <param name="status">0</param>
                    </url>
                    <type>disable</type>
                    <label translate="true">Disable</label>
                </settings>
            </action>
        </massaction>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="panth_heroslider_slide_columns">
        <settings>
            <editorConfig>
                <param name="indexField" xsi:type="string">entity_id</param>
                <param name="enabled" xsi:type="boolean">true</param>
                <param name="selectProvider" xsi:type="string">panth_heroslider_slide_listing.panth_heroslider_slide_listing.panth_heroslider_slide_columns.ids</param>
                <param name="clientConfig" xsi:type="array">
                    <item name="saveUrl" xsi:type="url" path="panth_heroslider/slide/inlineEdit"/>
                    <item name="validateBeforeSave" xsi:type="boolean">false</item>
                </param>
            </editorConfig>
            <childDefaults>
                <param name="fieldAction" xsi:type="array">
                    <item name="provider" xsi:type="string">panth_heroslider_slide_listing.panth_heroslider_slide_listing.panth_heroslider_slide_columns_editor</item>
                    <item name="target" xsi:type="string">startEdit</item>
                    <item name="params" xsi:type="array">
                        <item name="0" xsi:type="string">${ $.$data.rowIndex }</item>
                        <item name="1" xsi:type="boolean">true</item>
                    </item>
                </param>
            </childDefaults>
        </settings>
        <selectionsColumn name="ids">
            <settings>
                <indexField>entity_id</indexField>
            </settings>
        </selectionsColumn>
        <column name="entity_id" sortOrder="10">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>asc</sorting>
                <visible>true</visible>
            </settings>
        </column>
        <column name="image_desktop" sortOrder="20" class="Panth\HeroSlider\Ui\Component\Listing\Column\ImagePreview" component="Magento_Ui/js/grid/columns/thumbnail">
            <settings>
                <hasPreview>1</hasPreview>
                <altField>title</altField>
                <label translate="true">Desktop Image</label>
                <sortable>false</sortable>
            </settings>
        </column>
        <column name="title" sortOrder="30">
            <settings>
                <filter>text</filter>
                <label translate="true">Title</label>
            </settings>
        </column>
        <column name="slider_id" sortOrder="32" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <filter>select</filter>
                <dataType>select</dataType>
                <options class="Panth\HeroSlider\Model\Source\SliderOptions"/>
                <label translate="true">Slider Group</label>
            </settings>
        </column>
        <column name="link_url" sortOrder="40">
            <settings>
                <filter>text</filter>
                <label translate="true">Link URL</label>
            </settings>
        </column>
        <column name="button_label" sortOrder="50">
            <settings>
                <filter>text</filter>
                <label translate="true">Button Label</label>
            </settings>
        </column>
        <column name="sort_order" sortOrder="60">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Sort</label>
                <sorting>asc</sorting>
            </settings>
        </column>
        <column name="is_active" sortOrder="70" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <filter>select</filter>
                <dataType>select</dataType>
                <options class="Magento\Config\Model\Config\Source\Yesno"/>
                <label translate="true">Active</label>
            </settings>
        </column>
        <column name="views_30d" sortOrder="72" class="Panth\HeroSlider\Ui\Component\Listing\Column\StatColumn">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="metric" xsi:type="string">views</item>
                    <item name="sortable" xsi:type="boolean">false</item>
                </item>
            </argument>
            <settings>
                <label translate="true">Views (30d)</label>
            </settings>
        </column>
        <column name="clicks_30d" sortOrder="74" class="Panth\HeroSlider\Ui\Component\Listing\Column\StatColumn">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="metric" xsi:type="string">clicks</item>
                    <item name="sortable" xsi:type="boolean">false</item>
                </item>
            </argument>
            <settings>
                <label translate="true">Clicks (30d)</label>
            </settings>
        </column>
        <column name="ctr_30d" sortOrder="76" class="Panth\HeroSlider\Ui\Component\Listing\Column\StatColumn">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="metric" xsi:type="string">ctr</item>
                    <item name="sortable" xsi:type="boolean">false</item>
                </item>
            </argument>
            <settings>
                <label translate="true">CTR (30d)</label>
            </settings>
        </column>
        <column name="updated_at" sortOrder="80" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Updated</label>
            </settings>
        </column>
        <actionsColumn name="actions" class="Panth\HeroSlider\Ui\Component\Listing\Column\SlideActions" sortOrder="200">
            <settings>
                <indexField>entity_id</indexField>
                <resizeEnabled>false</resizeEnabled>
                <resizeDefaultWidth>120</resizeDefaultWidth>
            </settings>
        </actionsColumn>
    </columns>
</listing>
