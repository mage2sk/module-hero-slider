<?xml version="1.0"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">panth_heroslider_slider_listing.panth_heroslider_slider_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>panth_heroslider_slider_columns</spinner>
        <deps>
            <dep>panth_heroslider_slider_listing.panth_heroslider_slider_listing_data_source</dep>
        </deps>
        <buttons>
            <button name="add">
                <url path="*/*/new"/>
                <class>primary</class>
                <label translate="true">Add New Slider</label>
            </button>
        </buttons>
    </settings>
    <dataSource name="panth_heroslider_slider_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">slider_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>Panth_HeroSlider::sliders</aclResource>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider"
                      name="panth_heroslider_slider_listing_data_source">
            <settings>
                <requestFieldName>slider_id</requestFieldName>
                <primaryFieldName>slider_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <massaction name="listing_massaction">
            <action name="delete">
                <settings>
                    <confirm>
                        <message translate="true">Are you sure you want to delete the selected sliders? Slides assigned to them will lose their group reference.</message>
                        <title translate="true">Delete sliders</title>
                    </confirm>
                    <url path="panth_heroslider/slider/massDelete"/>
                    <type>delete</type>
                    <label translate="true">Delete</label>
                </settings>
            </action>
        </massaction>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="panth_heroslider_slider_columns">
        <selectionsColumn name="ids">
            <settings>
                <indexField>slider_id</indexField>
            </settings>
        </selectionsColumn>
        <column name="slider_id" sortOrder="10">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>asc</sorting>
            </settings>
        </column>
        <column name="name" sortOrder="20">
            <settings>
                <filter>text</filter>
                <label translate="true">Name</label>
            </settings>
        </column>
        <column name="identifier" sortOrder="30">
            <settings>
                <filter>text</filter>
                <label translate="true">Identifier</label>
            </settings>
        </column>
        <column name="store_ids" sortOrder="35" class="Panth\HeroSlider\Ui\Component\Listing\Column\SliderStores">
            <settings>
                <label translate="true">Store Views</label>
                <sortable>false</sortable>
                <filter>false</filter>
            </settings>
        </column>
        <column name="is_active" sortOrder="40" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <filter>select</filter>
                <dataType>select</dataType>
                <options class="Magento\Config\Model\Config\Source\Yesno"/>
                <label translate="true">Active</label>
            </settings>
        </column>
        <column name="updated_at" sortOrder="50" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Updated</label>
            </settings>
        </column>
        <actionsColumn name="actions" class="Panth\HeroSlider\Ui\Component\Listing\Column\SliderActions" sortOrder="200">
            <settings>
                <indexField>slider_id</indexField>
                <resizeEnabled>false</resizeEnabled>
            </settings>
        </actionsColumn>
    </columns>
</listing>
