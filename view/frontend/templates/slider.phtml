$first    = $slides[0] ?? null;
?>
<link rel="stylesheet" href="<?= $escaper->escapeUrl($block->getSplideCssUrl()) ?>">
<div class="panth-hero" id="<?= $escaper->escapeHtmlAttr($sliderId) ?>" role="region" aria-roledescription="carousel">
    <?php if ($first): ?>
        <div class="panth-hero__lcp">
            <a class="panth-hero__slide" href="<?= $escaper->escapeUrl($block->getLinkUrl($first)) ?>">
                <span class="panth-hero__btn"
                      style="background-color: <?= $escaper->escapeHtmlAttr($block->getButtonBg($first)) ?>; color: <?= $escaper->escapeHtmlAttr($block->getButtonColor($first)) ?>;">
                    <?= $escaper->escapeHtml($block->getButtonLabel($first)) ?>
                </span>
                <picture>
                    <source srcset="<?= $escaper->escapeUrl($block->getMobileSrc($first)) ?>" media="(max-width: 767px)">
                    <img src="<?= $escaper->escapeUrl($block->getDesktopSrc($first)) ?>"
                         alt="<?= $escaper->escapeHtmlAttr($block->getAlt($first)) ?>"
                         width="706" height="390" fetchpriority="high" loading="eager">
                </picture>
            </a>
        </div>
    <?php endif; ?>

    <div class="splide__track">
        <ul class="splide__list">
            <?php foreach ($slides as $slide): ?>
                <li class="splide__slide panth-hero__slide-wrap">
                    <a class="panth-hero__slide" href="<?= $escaper->escapeUrl($block->getLinkUrl($slide)) ?>">
                        <span class="panth-hero__btn"
                              style="background-color: <?= $escaper->escapeHtmlAttr($block->getButtonBg($slide)) ?>; color: <?= $escaper->escapeHtmlAttr($block->getButtonColor($slide)) ?>;">
                            <?= $escaper->escapeHtml($block->getButtonLabel($slide)) ?>
                        </span>
                        <picture>
                            <source srcset="<?= $escaper->escapeUrl($block->getMobileSrc($slide)) ?>" media="(max-width: 767px)">
                            <img src="<?= $escaper->escapeUrl($block->getDesktopSrc($slide)) ?>"
                                 alt="<?= $escaper->escapeHtmlAttr($block->getAlt($slide)) ?>"
                                 width="706" height="390" loading="lazy">
                        </picture>
                    </a>
                </li>
            <?php endforeach; ?>
        </ul>
    </div>
</div>

<script>
    'use strict';
    (function () {
        var SLIDER_ID = <?= /* @noEscape */ json_encode($sliderId) ?>;
        var SPLIDE_CONFIG = <?= /* @noEscape */ $block->getSplideConfigJson() ?>;
        var SPLIDE_JS_URL = <?= /* @noEscape */ json_encode($block->getSplideJsUrl()) ?>;

        var mountSlider = function () {
            if (typeof window.Splide === 'undefined') return;
            var el = document.getElementById(SLIDER_ID);
            if (!el) return;
            // Splide expects the library's "splide" class on the root element.
            el.classList.add('splide');
            try {
                new window.Splide('#' + SLIDER_ID, SPLIDE_CONFIG).mount();
                el.classList.add('panth-hero--mounted');
            } catch (e) {
                if (window.console && console.warn) console.warn('panth-hero-slider mount failed', e);
            }
        };

        // Splide ships as a UMD bundle. When it sees `define.amd` it
        // registers as an anonymous AMD module — which Magento's RequireJS
        // rejects with "Mismatched anonymous define()" because we're loading
        // the script via a `<script>` tag, not via require().
        // The fix: temporarily hide ONLY `define.amd` (not `define` itself),
        // forcing the UMD wrapper to take its browser-global branch and
        // assign `window.Splide`. Other RequireJS modules keep working
        // because `define` is untouched.
        var loadSplideAndMount = function () {
            if (typeof window.Splide !== 'undefined') {
                mountSlider();
                return;
            }
            window.__panthHeroSplideLoading = window.__panthHeroSplideLoading || new Promise(function (resolve) {
                var hadAmd = !!(window.define && window.define.amd);
                var savedAmd = hadAmd ? window.define.amd : undefined;
                if (hadAmd) {
                    try { window.define.amd = undefined; } catch (e) { /* read-only on some loaders */ }
                }
                var restore = function () {
                    if (hadAmd && window.define) {
                        try { window.define.amd = savedAmd; } catch (e) { /* ignore */ }
                    }
                };
                var s = document.createElement('script');
                s.src = SPLIDE_JS_URL;
                s.async = true;
                s.addEventListener('load',  function () { restore(); resolve(); });
                s.addEventListener('error', function () { restore(); resolve(); });
                document.head.appendChild(s);
            });
            window.__panthHeroSplideLoading.then(mountSlider);
        };

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', loadSplideAndMount);
        } else {
            loadSplideAndMount();
        }
    })();
</script>
